{
  "info": {
    "_postman_id": "localmind-api-collection",
    "name": "LocalMind API",
    "description": "Complete REST API collection for LocalMind application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": ["{{base_url}}"],
              "path": ["register"]
            },
            "description": "Register a new user account"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "description": "Login and get access token"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            },
            "description": "Logout and revoke access token"
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "List Questions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/questions?page=1",
              "host": ["{{base_url}}"],
              "path": ["questions"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "location",
                  "value": "Paris",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "python",
                  "disabled": true
                },
                {
                  "key": "latitude",
                  "value": "48.8566",
                  "disabled": true
                },
                {
                  "key": "longitude",
                  "value": "2.3522",
                  "disabled": true
                },
                {
                  "key": "radius",
                  "value": "10",
                  "disabled": true
                }
              ]
            },
            "description": "Get paginated list of questions with optional filtering"
          }
        },
        {
          "name": "Get Question Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/questions/1",
              "host": ["{{base_url}}"],
              "path": ["questions", "1"]
            },
            "description": "Get a specific question with responses"
          }
        },
        {
          "name": "Create Question",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"How to learn Laravel?\",\n  \"content\": \"I'm interested in learning Laravel framework for web development...\",\n  \"location\": \"Paris\",\n  \"latitude\": 48.8566,\n  \"longitude\": 2.3522\n}"
            },
            "url": {
              "raw": "{{base_url}}/questions",
              "host": ["{{base_url}}"],
              "path": ["questions"]
            },
            "description": "Create a new question (requires authentication)"
          }
        },
        {
          "name": "Update Question",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\",\n  \"content\": \"Updated content\",\n  \"location\": \"Lyon\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/questions/1",
              "host": ["{{base_url}}"],
              "path": ["questions", "1"]
            },
            "description": "Update your own question"
          }
        },
        {
          "name": "Delete Question",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/questions/1",
              "host": ["{{base_url}}"],
              "path": ["questions", "1"]
            },
            "description": "Delete a question"
          }
        }
      ]
    },
    {
      "name": "Responses",
      "item": [
        {
          "name": "List Responses for Question",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/questions/1/responses?page=1",
              "host": ["{{base_url}}"],
              "path": ["questions", "1", "responses"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            },
            "description": "Get paginated responses for a question"
          }
        },
        {
          "name": "Create Response",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"I recommend checking out Laravel's official documentation and tutorials...\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/questions/1/responses",
              "host": ["{{base_url}}"],
              "path": ["questions", "1", "responses"]
            },
            "description": "Add a response to a question"
          }
        },
        {
          "name": "Delete Response",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/responses/1",
              "host": ["{{base_url}}"],
              "path": ["responses", "1"]
            },
            "description": "Delete a response (owner or admin only)"
          }
        }
      ]
    },
    {
      "name": "Favorites",
      "item": [
        {
          "name": "List Favorites",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/favorites?page=1",
              "host": ["{{base_url}}"],
              "path": ["favorites"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            },
            "description": "Get user's favorite questions"
          }
        },
        {
          "name": "Toggle Favorite",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/questions/1/favorite",
              "host": ["{{base_url}}"],
              "path": ["questions", "1", "favorite"]
            },
            "description": "Add or remove a question from favorites"
          }
        }
      ]
    },
    {
      "name": "User Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/user",
              "host": ["{{base_url}}"],
              "path": ["user"]
            },
            "description": "Get current user's profile and statistics"
          }
        }
      ]
    },
    {
      "name": "Statistics",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/stats",
              "host": ["{{base_url}}"],
              "path": ["dashboard", "stats"]
            },
            "description": "Get dashboard statistics (admin gets additional stats)"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
